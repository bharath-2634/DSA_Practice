# Bruteforce
import java.util.*;

class Main {

    private static int MOD = 1_000_000_007;
    
    public static int maxProfitContinousBags(int k,int n,int[][] bags) {
        int max_size=0;

        for(int i=0;i<n;i++) {
            int end = bags[i][1];
            max_size = Math.max(max_size,end);
        }

        int[] money_bag = new int[max_size];

        for(int i=0;i<n;i++) {
            for(int j=bags[i][0]-1;j<bags[i][1];j++) {
                money_bag[j] = bags[i][2];
            }
        }

        int max_amount = Integer.MIN_VALUE;

        for(int i=0;i<max_size;i++) {
            boolean flag = false;
            int sum = 0;
            for(int j=0;j<k && j+i<max_size;j++) {
                if(j+i>=max_size) {
                    flag = true;
                    break;
                }
                sum+=money_bag[j+i];
            }
            if(flag) break;
            max_amount = Math.max(max_amount,sum);
        }

        return max_amount%MOD;
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int k = sc.nextInt();
        int n = sc.nextInt();

        int[][] bags = new int[n][3];

        for(int i=0;i<n;i++) {
            bags[i][0] = sc.nextInt();
            bags[i][1] = sc.nextInt();
            bags[i][2] = sc.nextInt();
        }

        System.out.println(maxProfitContinousBags(k,n,bags));
    }
}
