class Solution {
    
    public boolean getIsInterleave(int idx1,int idx2,String s1,String s2,String s3,Boolean[][] dp) {

        if(idx1==s1.length() && idx2==s2.length()) {
            if((idx1+idx2)==s3.length()) return true;
            else return false;
        }

        int idx3 = idx1+idx2;

        if(idx1>=s1.length()) {
            // add all the s2
            if(idx3<s3.length() && s2.charAt(idx2)==s3.charAt(idx3)) {
                return dp[idx1][idx2] = getIsInterleave(idx1,idx2+1,s1,s2,s3,dp);
            }

            return false;
        }

        if(idx2>=s2.length()) {
            // add all the s1
            if(idx3<s3.length() && s1.charAt(idx1)==s3.charAt(idx3)) {
                return dp[idx1][idx2] = getIsInterleave(idx1+1,idx2,s1,s2,s3,dp);
            }

            return false;
        }

        if(dp[idx1][idx2]!=null) return dp[idx1][idx2];
        
        //choose s1
        boolean choose_s1 = false;
        if(idx3<s3.length() && s1.charAt(idx1)==s3.charAt(idx3)) {
            choose_s1 = getIsInterleave(idx1+1,idx2,s1,s2,s3,dp);
        }

        //choose s2
        boolean choose_s2 = false;
        if(idx3<s3.length() && s2.charAt(idx2)==s3.charAt(idx3)) {
            choose_s2 = getIsInterleave(idx1,idx2+1,s1,s2,s3,dp);
        } 

        return dp[idx1][idx2] = (choose_s1 || choose_s2);
    }

    public boolean isInterleave(String s1,String s2,String s3) {
        Boolean[][] dp = new Boolean[s1.length()+1][s2.length()+1];
        return getIsInterleave(0,0,s1,s2,s3,dp);
    }
}
