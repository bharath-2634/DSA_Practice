import java.util.*;

class Printer extends Thread {
    @Override
    public void run() {
        for(int i=0;i<50;i++) {
            System.out.println("Child Thread Process: "+currentThread().getName()+" " +i);
        }
        
    }
} 

class Main {
    public static void main(String[] args) {
        Printer p = new Printer();
        p.setDaemon(true);
        p.start();

        for(int i=0;i<50;i++) {
            System.out.println("main Thread Process: "+Thread.currentThread().getName() + " " +i);
        }

    }
}

In this case, the application terminates the execution when the main thread exits. It means the printerThread might not be able to print up to “Thread-0 49”
