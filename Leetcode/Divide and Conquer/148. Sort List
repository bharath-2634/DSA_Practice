class Solution {

    public ListNode findMiddleNode(ListNode node) {
        if(node==null) return null;

        ListNode slow= node,fast=node;

        while(fast!=null && fast.next!=null) {
            fast = fast.next.next;
            if(fast!=null) slow = slow.next;
        }

        ListNode split = slow.next;
        slow.next = null;

        return split;
    }

    public ListNode merge(ListNode left,ListNode right) {
        if(left==null && right==null) return null;
        if(left==null) return right;
        if(right==null) return left;

        if(left.val < right.val) {
            left.next = merge(left.next,right);
            return left;
        }else {
            right.next = merge(left,right.next);
            return right;
        }

    }

    public ListNode mergeSort(ListNode node) {
        if(node==null || node.next==null) return node;

        ListNode middle = findMiddleNode(node);
        node = mergeSort(node);
        middle = mergeSort(middle);


        return merge(node,middle);
    }

    public ListNode sortList(ListNode node) {
        return mergeSort(node);
    }
}
