Question: https://leetcode.com/problems/minimum-removals-to-achieve-target-xor/

Solution:

class Solution {

    public int getMinRemovals(int idx,int xor,int[] nums,int target,int[][] dp) {
        if(idx==nums.length) {
            return xor==target ? 0 : Integer.MAX_VALUE/2;
        }

        if(dp[idx][xor]!=0) return dp[idx][xor];

        int not_take= getMinRemovals(idx+1,xor^nums[idx],nums,target,dp);
        int take = 1+getMinRemovals(idx+1,xor,nums,target,dp);
        
        return dp[idx][xor] = Math.min(not_take,take);
    }

    public int minRemovals(int[] nums, int target) {
        int[][] dp = new int[nums.length][100000];
        int res = getMinRemovals(0,0,nums,target,dp);
        return res>=Integer.MAX_VALUE/2 ? -1: res;
    }
}
