    public boolean canSplit(int[] nums,int k,int mid) {
        int split_count=1,sum=0;

        for(int num: nums) {
            if(num>mid) return false;

            if(sum+num>mid) {
                sum=0;
                split_count++;

                if(split_count>k) return false;
            }
            sum+=num;
        }

        return true;
    }

    public int splitArray(int[] nums,int k) {
        int left=0,right=0,res=0;

        for(int num : nums) {
            left = Math.max(left,num);
            right+=num;
        }

        if(k==1) return right;

        while(left<right) {
            int mid = left+(right-left)/2;
            
            if(canSplit(nums,k,mid)) {
                res =mid;
                right = mid;
            } else left = mid+1;
        }

        return res;
    }
}
