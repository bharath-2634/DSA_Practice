Question: https://leetcode.com/problems/koko-eating-bananas/

Solution:
class Solution {
    public int getMax(int[] piles) {
        int max=Integer.MIN_VALUE;
        for(int p : piles) {
            max=  Math.max(max,p);
        }

        return max;
    }

    public boolean canEat(int[] piles,int k,int h) {
        int number_hrs=0;
        for(int p: piles) {
            number_hrs+=(p+k-1)/k;
        }
        return (number_hrs<=h);
    }

    public int minEatingSpeed(int[] piles, int h) {
        int left=1,right=getMax(piles);

        while(left<right) {
            int mid = left+(right-left)/2;
            if(canEat(piles,mid,h)) {
                right = mid;
            }else left = mid+1;
        }

        return left;
    }
}
