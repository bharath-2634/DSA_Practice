Question: https://leetcode.com/problems/minimized-maximum-of-products-distributed-to-any-store/

Solution:
class Solution {

    public int getMax(int[] nums) {
        int max=Integer.MIN_VALUE;

        for(int num: nums) max = Math.max(max,num);

        return max;
    }

    public boolean canDistribute(int n,int[] quantities,int mid) {
        int next=0;
        int remaining = quantities[next];

        for(int i=0;i<n;i++) {
            if(remaining<=mid) {
                next++;
                if(next==quantities.length) return true;
                else remaining= quantities[next];
            }else {
                remaining-=mid;
            }
        }

        return false;
    }

    public int minimizedMaximum(int n, int[] quantities) {
        int left=0,right=getMax(quantities);

        while(left<right) {
            int mid = left+(right-left)/2;

            if(canDistribute(n,quantities,mid)) {
                right = mid;
            }else {
                left = mid+1;
            }
        }

        return left;
    }
}
