Question: https://leetcode.com/problems/peak-index-in-a-mountain-array/

Solution:

class Solution {
    public int peakIndexInMountainArray(int[] nums) {
        int left=1,right=nums.length-1;

        while(left<right) {
            int mid = left+(right-left)/2;
            if(nums[mid]>nums[mid+1]) {
                right=mid;
            }else {
                left = mid+1;
            }
        }

        return left;
    }
}
