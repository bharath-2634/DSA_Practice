Question: https://leetcode.com/problems/minimum-cost-to-make-at-least-one-valid-path-in-a-grid/

Solution:
class Solution {
    public int minCost(int[][] grid) {
        int n = grid.length, m=grid[0].length;
        Deque<int[]> q = new ArrayDeque<>();
        int min_cost = Integer.MAX_VALUE;
        boolean[][] visited = new boolean[n][m];
        q.addFirst(new int[]{0,0,0});
        // visited[0][0] = true;

        int[] dir_r= {0,0,0,+1,-1};
        int[] dir_c = {0,1,-1,0,0};

        while(!q.isEmpty()) {
            int[] pos = q.pollFirst();
            int row=pos[0], col=pos[1], cur_cost=pos[2];
        
            if(row==n-1 && col==m-1) {
                min_cost = Math.min(min_cost,cur_cost);
                // continue;
            }

            if(row<0 || col<0 || row>=n || col>=m) continue;
            if(visited[row][col]) continue;
            visited[row][col]=true;

            for(int i=1; i<=4; i++) {
                int new_row = row + dir_r[i];
                int new_col = col + dir_c[i];

                // Skip if out of bounds or visited
                if(new_row<0 || new_col<0 || new_row>=n || new_col>=m || visited[new_row][new_col]) {
                    continue;
                }

                // If this direction matches the arrow on the cell -> Cost 0 (Front)
                if(grid[row][col] == i) {
                    q.addFirst(new int[]{new_row, new_col, cur_cost});
                } else {
                    q.addLast(new int[]{new_row, new_col, cur_cost+1});
                }
            }
            
            
            // if() {
            //     // using coin phase
            //     q.addLast(new int[]{next_row,next_col,cur_cost+1});
            // }

            // not using coin phase
            
        }

        return min_cost;
    }
}
