class Solution {

    private int min_count=0;

    public void generateAdjList(int[][] connections,Map<Integer,List<int[]>> adjList) {

        for(int[] connection : connections) {
            int u = connection[0];
            int v = connection[1];

            adjList.computeIfAbsent(u,k->new ArrayList<>()).add(new int[]{v,1});
            adjList.computeIfAbsent(v,k->new ArrayList<>()).add(new int[]{u,0});
        }
    }

    public void dfs(int node,int parent,Map<Integer,List<int[]>> adjList) {

        for(int[] adjComp : adjList.getOrDefault(node,new ArrayList<>())) {
            int adjNode = adjComp[0], change=adjComp[1];

            if(adjNode!=parent) {
                min_count+=change;
                dfs(adjNode,node,adjList);
            }
        }
    }

    public int minReorder(int n, int[][] connections) {
        Map<Integer,List<int[]>> adjList = new HashMap<>();
        generateAdjList(connections,adjList);

        dfs(0,-1,adjList);

        return min_count;

    }
}
