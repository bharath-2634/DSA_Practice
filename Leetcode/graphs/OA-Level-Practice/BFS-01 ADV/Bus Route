class Solution {
    public void generateAdjList(int[][] routes,Map<Integer,List<int[]>> adjList) {

        for(int i=0;i<routes.length;i++) {
            for(int j=1;j<routes[i].length;j++) {
               
                int next_bus = routes[i][j];
                adjList.computeIfAbsent(routes[i][j-1],k->new ArrayList<>()).add(new int[]{next_bus,i});
                
            }

            int next_bus = routes[i][0];
            adjList.computeIfAbsent(routes[i][routes[i].length-1],k->new ArrayList<>()).add(new int[]{next_bus,i});
        }
    }

    public int numBusesToDestination(int[][] routes, int source, int target) {
        
        if(source==target) return 0;

        Map<Integer,List<int[]>> adjList = new HashMap<>();
        generateAdjList(routes,adjList);

        Deque<int[]> queue = new ArrayDeque<>();
        Set<String> visited = new HashSet<>();
        
        for(int[] adjComp : adjList.getOrDefault(source,new ArrayList<>())) {
            int bus = adjComp[1];
            queue.addFirst(new int[]{source,bus,1});
            // visited.add(source+" | "+bus);
        }

        while(!queue.isEmpty()) {
            int[] src = queue.pollFirst();
            int cur_station = src[0], cur_bus = src[1], cur_exchange=src[2];

            if(cur_station==target) {
                return cur_exchange;
            }

            String key = cur_station + " | "+cur_bus;

            if(visited.contains(key)) continue;
            visited.add(key);

            for(int[] adjComp : adjList.getOrDefault(cur_station,new ArrayList<>())) {
                int station = adjComp[0], bus = adjComp[1];
                String cur_key = station + " | "+bus;

                if(!visited.contains(cur_key)) {
                    // visited.add(key);

                    if(cur_bus==bus) {
                        queue.addFirst(new int[]{station, bus,  cur_exchange});
                    }else {
                        queue.addLast(new int[]{station,bus,cur_exchange+1});
                    }
                }

            }
        }

        return -1;

    }

}
