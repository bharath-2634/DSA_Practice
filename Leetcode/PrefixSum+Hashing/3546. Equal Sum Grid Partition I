class Solution {

    public boolean checkSplit(int[] nums,long total_sum) {
        long cur_sum=0;
        for(int i=0;i<nums.length-1;i++) {
            cur_sum+=nums[i];
            long rem_sum = total_sum-cur_sum;

            if(cur_sum==rem_sum) return true;
        }

        return false;
    }

    public boolean canPartitionGrid(int[][] grid) {
        int[] row_sum = new int[grid.length];
        int[] col_sum = new int[grid[0].length];
        long total_sum =0;

        for(int i=0;i<grid.length;i++) {
            for(int j=0;j<grid[0].length;j++) {
                row_sum[i]+=grid[i][j];
                col_sum[j]+=grid[i][j];
                total_sum+=grid[i][j];
            }
        }

        if(checkSplit(row_sum,total_sum) || checkSplit(col_sum,total_sum)) return true;

        return false;
    }
}

