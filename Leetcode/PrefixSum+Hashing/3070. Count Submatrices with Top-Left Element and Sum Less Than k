Question: https://leetcode.com/problems/count-submatrices-with-top-left-element-and-sum-less-than-k/

Solution:

class Solution {
    public int countSubmatrices(int[][] grid, int k) {
        int[][] prefix_grid = new int[grid.length][grid[0].length];

        prefix_grid[0][0] = grid[0][0];
        for(int i=1;i<grid[0].length;i++) {
            prefix_grid[0][i] = prefix_grid[0][i-1] + grid[0][i];
            
        }

        for(int i=1;i<grid.length;i++) {
            prefix_grid[i][0] = prefix_grid[i-1][0] + grid[i][0];
            
        }

        for(int i=1;i<grid.length;i++) {
            for(int j=1;j<grid[0].length;j++) {
                prefix_grid[i][j] = grid[i][j] + prefix_grid[i-1][j] + prefix_grid[i][j-1] - prefix_grid[i-1][j-1];
                // System.out.println(prefix_grid[i][j]);
            }
        }

        int count=0;

        for(int i=0;i<grid.length;i++) {
            for(int j=0;j<grid[0].length;j++) {
                if(prefix_grid[i][j]<=k) {
                    count++;
                }
            }
        }

        return count;
    }
}
