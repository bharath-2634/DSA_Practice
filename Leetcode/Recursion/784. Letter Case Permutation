    public List<String> letterCasePermutation(String s) {
        List<String> res = new ArrayList<>();
        getLetterCasePermutation(0,s.toCharArray(),res);

        return res;
    }

    public void getLetterCasePermutation(int idx,char[] s,List<String> res) {
        if(idx>s.length) return;

        if(idx==s.length) {
            res.add(String.valueOf(s));
            return;
        }

        if(Character.isDigit(s[idx])) {
            getLetterCasePermutation(idx+1,s,res);
        }else {
            getLetterCasePermutation(idx+1,s,res);
            char temp = s[idx];
            if(Character.isLowerCase(temp)) s[idx] = Character.toUpperCase(temp);
            else s[idx] = Character.toLowerCase(temp);
            getLetterCasePermutation(idx+1,s,res);
            s[idx] = temp;
        }
    }
}
